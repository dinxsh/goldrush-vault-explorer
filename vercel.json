{
  "buildCommand": "npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "env": {
    "NODE_ENV": "production"
  },
  "regions": ["iad1"],
  "functions": {
    "app/api/**": {
      "maxDuration": 60,
      "memory": 1024
    },
    "app/earn/**": {
      "maxDuration": 30,
      "memory": 512
    },
    "app/portfolio/**": {
      "maxDuration": 30,
      "memory": 512
    }
  },
  "redirects": [],
  "rewrites": [],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=60, s-maxage=120"
        }
      ]
    },
    {
      "source": "/api/opportunities",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
